{
  "name": "bobe-agent",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --env-file-if-exists=.env --test tests/*.test.js core/*.test.js mcp/*.test.js bin/*.test.js",
    "test:api": "vitest run --root api",
    "test:front": "vitest run --root front",
    "test:all": "npm run typecheck && npm test && npm run test:api && npm run test:front",
    "test:db:reset": "bash db/migrate.sh \"${DB_TEST_DATABASE:-bobe_agent_test}\"",
    "typecheck": "npm run typecheck:api && npm run typecheck:front",
    "typecheck:api": "tsc -p api/tsconfig.json --noEmit",
    "typecheck:front": "tsc -p front/tsconfig.json --noEmit",
    "dev": "concurrently -n api,front -c blue,green \"npm:api:dev\" \"npm:front:dev\"",
    "api:dev": "tsx watch api/src/index.ts",
    "api:start": "node --env-file=.env --import tsx api/src/index.ts",
    "start:mcp": "node mcp/index.js",
    "candles:refresh": "node --env-file-if-exists=.env bin/refresh-candles.mjs",
    "front:dev": "vite front",
    "front:build": "vite build front",
    "front:preview": "vite preview front",
    "test:e2e": "playwright test -c front/playwright.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tanstack/react-query": "^5.59.0",
    "big.js": "^6.2.2",
    "clsx": "^2.1.1",
    "fastify": "^5.0.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.451.0",
    "pg": "^8.13.0",
    "pino": "^9.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.23.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.0",
    "@types/big.js": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.3",
    "jsdom": "^25.0.0",
    "msw": "^2.4.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
