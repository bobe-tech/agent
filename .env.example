# Model of the tick-agent and the reflection-job
AGENT_MODEL=claude-sonnet-4-6
REFLECTION_MODEL=claude-sonnet-4-6

# Environment and blockchain access for reading the swap receipt in fill_order (core/blockchain.js).
# WALLET_ADDRESS — the trading wallet (DIFFERENT per environment!).
# BSC_RPC_URL — the RPC endpoint (Tatum gateway or public); TATUM_API_KEY — if the RPC is Tatum (the x-api-key header).
APP_ENV=local
WALLET_ADDRESS=
BSC_RPC_URL=
TATUM_API_KEY=
BSC_RPC_RETRIES=5
BSC_RPC_RETRY_DELAY_MS=5000
# DB
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=bobe_agent
DB_USERNAME=
DB_PASSWORD=
# External services
CMC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Send ALL ticks to Telegram, including HOLDs with no actions (1 = verbose/debug). By default we send
# only trades (open/add/close), closes, tick failures and reflection outputs.
TELEGRAM_NOTIFY_HOLD=0

# Test DBs (isolated autotests; the tests do not touch the prod DB).
# The name must contain 'test' — otherwise the tests/db.js safeguard refuses to work.
DB_TEST_HOST=localhost
DB_TEST_PORT=5432
DB_TEST_DATABASE=bobe_agent_test
DB_TEST_USERNAME=
DB_TEST_PASSWORD=

# Public front URL (no trailing slash). At build time it is substituted into og:image/og:url/twitter:image
# (index.html), so that Telegram/social networks pull the preview from the correct domain. In prod switch to the live one.
VITE_APP_URL=http://localhost:5173
# Web API (Fastify): host, port, CORS allowlist (comma-separated; empty = any Origin, only for dev/demo)
# API_HOST defaults to 127.0.0.1 (loopback) — the API is unauthenticated and read-only, so expose it only
# through a reverse proxy (TLS/auth). Set API_HOST=0.0.0.0 to bind all interfaces (do this on the proxy host).
API_HOST=127.0.0.1
API_PORT=3001
CORS_ORIGINS=
# API logs: level and file (logs are written both to stdout and to the file). API_DEBUG=true — return to the outside
# the real text of 5xx errors (default false: the client sees a generic message, the details — only in the log).
LOG_LEVEL=info
API_LOG_FILE=logs/api.log
API_DEBUG=false
# Candles: the refresh-candles cron pulls 1h for all pairs and upserts into the candles table; the API reads from the DB.
# How many days of 1h history to keep (the strategy needs ~30; we take some margin).
CANDLES_KEEP_DAYS=45
